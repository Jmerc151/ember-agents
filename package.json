    "build": "vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@tailwindcss/vite": "^4.1.8",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.8",
    "vite": "^7.3.1"
  }
}
